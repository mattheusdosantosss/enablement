# Token do Private App HubSpot
# Scopes necessários: crm.objects.deals.read, crm.objects.tickets.read,
#                     crm.objects.meetings.read, crm.objects.owners.read
HUBSPOT_TOKEN=

# ── B2B ─────────────────────────────────────────────────────────────────────
HUBSPOT_PIPELINE_B2B=           # ID do pipeline de B2B
HUBSPOT_B2B_STAGE_NEGOTIATION=  # ID da etapa "Em Negociação"
HUBSPOT_B2B_PROP_REVENUE=amount # Propriedade de receita líquida (ex: receita_liquida)

# ── B2C ─────────────────────────────────────────────────────────────────────
HUBSPOT_PIPELINE_B2C=           # ID do pipeline de B2C
HUBSPOT_B2C_PROP_REVENUE=amount # Propriedade de receita líquida
HUBSPOT_B2C_PROP_PRODUCT=       # Propriedade de produto vendido

# ── Farmer ───────────────────────────────────────────────────────────────────
HUBSPOT_PIPELINE_FARMER=        # ID do pipeline de Farmer (deals)
HUBSPOT_PIPELINE_CS=748675953   # ID do pipeline CS (tickets)
HUBSPOT_CS_STAGE_IN_PROGRESS=   # ID da etapa "Em andamento" no CS
HUBSPOT_FARMER_PROP_REVENUE=amount
HUBSPOT_FARMER_PROP_ORIGIN=origem_do_lead
HUBSPOT_FARMER_ORIGIN_VALUE=Carteira do Farmer
